# Staging environment template (backend)
# Copy to: backend/.env.staging

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-strong-random-secret
DJANGO_ALLOWED_HOSTS=staging-api.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.yourdomain.com,https://staging-api.yourdomain.com
DJANGO_CORS_ALLOWED_ORIGINS=https://staging.yourdomain.com
FRONTEND_BASE_URL=https://staging.yourdomain.com
DEFAULT_FROM_EMAIL=Chirin Ivatan <noreply@staging.yourdomain.com>

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.your-email-provider.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=replace-with-smtp-username
DJANGO_EMAIL_HOST_PASSWORD=replace-with-smtp-password
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=20

DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=chirin_staging
DJANGO_DB_USER=chirin_staging_user
DJANGO_DB_PASSWORD=replace-with-strong-password
DJANGO_DB_HOST=replace-with-staging-db-host
DJANGO_DB_PORT=5432

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

DJANGO_STATIC_ROOT=<staging-public-root>/static
DJANGO_MEDIA_ROOT=<staging-public-root>/media
