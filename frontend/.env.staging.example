# Staging environment template (frontend)
# Copy to: frontend/.env.staging

# Same-origin deployment:
# VITE_API_BASE=

# Separate API domain deployment:
VITE_API_BASE=https://staging-api.yourdomain.com
VITE_TURNSTILE_SITE_KEY=replace-with-cloudflare-turnstile-site-key
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
